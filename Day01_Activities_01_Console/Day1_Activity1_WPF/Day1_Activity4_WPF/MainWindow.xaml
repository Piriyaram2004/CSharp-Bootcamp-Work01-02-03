<Window x:Class="Day1_Activity4_WPF_.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Day1_Activity4_WPF_"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="Black"/>
                <GradientStop Color="#FF2DEC2F" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="397*"/>
        </Grid.ColumnDefinitions>
        <TextBox x:Name="NUM1" Grid.Column="1" HorizontalAlignment="Left" Margin="212,96,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="114" RenderTransformOrigin="0.483,1.7" Height="45" Foreground="White">
            <TextBox.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black"/>
                    <GradientStop Color="White" Offset="1"/>
                </LinearGradientBrush>
            </TextBox.Background>
        </TextBox>
        <TextBox x:Name="NUM2" Grid.Column="1" HorizontalAlignment="Left" Margin="412,96,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="110" RenderTransformOrigin="1.352,-1.487" Height="45" Foreground="White">
            <TextBox.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black"/>
                    <GradientStop Color="White" Offset="1"/>
                </LinearGradientBrush>
            </TextBox.Background>
        </TextBox>
        <Button x:Name="ADD" Grid.Column="1" Content="ADD" HorizontalAlignment="Left" Margin="300,0,0,0" VerticalAlignment="Center" Height="33" Width="52" Foreground="#FFEFEFEF" Background="#FFF90C0C" Click="ADD_Click"/>
        <Button x:Name="SUBTRACT" Grid.Column="1" Content="SUBTRACT" HorizontalAlignment="Left" Margin="194,0,0,0" VerticalAlignment="Center" Height="33" RenderTransformOrigin="-3.256,1.172" Width="60" BorderBrush="#FFD41A1A" Foreground="Black" Background="#FF64E211" Click="SUBTRACT_Click"/>
        <Button x:Name="MULTIPLY" Grid.Column="1" Content="MULTIPLY" HorizontalAlignment="Left" Margin="502,201,0,0" VerticalAlignment="Top" Height="35" RenderTransformOrigin="3.527,-3.305" Width="69" Foreground="#FFE8E8E8" Background="#FF0F49FB" Click="MULTIPLY_Click"/>
        <Button x:Name="DIVISION" Grid.Column="1" Content="DIVISION" HorizontalAlignment="Left" Margin="397,0,0,0" VerticalAlignment="Center" RenderTransformOrigin="-2.227,2.582" Height="34" Width="57" Background="#FFD611F7" Foreground="White" Click="DIVISION_Click"/>
        <TextBlock x:Name="result" Grid.Column="1" HorizontalAlignment="Left" Margin="85,314,0,0" TextWrapping="Wrap" Text="Results shown here " VerticalAlignment="Top" RenderTransformOrigin="0.5,0.5" Width="508" Height="87" Background="Black" Foreground="#FFFBFBFB" FontSize="24">
            <TextBlock.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="-0.596"/>
                    <TranslateTransform/>
                </TransformGroup>
            </TextBlock.RenderTransform>
        </TextBlock>

    </Grid>
</Window>
